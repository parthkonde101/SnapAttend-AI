# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://snapattend:snapattend@localhost:5432/snapattend

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - comma separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
PROJECT_NAME=SnapAttend
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

# Local directory (relative to backend/) where uploaded attendance photos are stored
UPLOAD_DIR=uploads/attendance-photos

# Local directory (relative to backend/) where registration ID-card captures
# are stored once they pass the image quality gate (development only)
REGISTRATION_UPLOAD_DIR=uploads/registration-photos
