# Base URL of the FastAPI backend. Pick the line that matches how you're
# running things and comment out the others.

# Local development (backend running on the same machine as the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# LAN testing on a phone (iPhone Safari / Android Chrome) — replace with
# your computer's LAN IP so a phone on the same Wi-Fi can reach the backend.
# Find it with `ipconfig getifaddr en0` (macOS) or `ipconfig` (Windows).
# NEXT_PUBLIC_API_URL=http://192.168.1.42:8000

# Production
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
